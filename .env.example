# Optional production analytics and webmaster verification values.
# Leave blank to disable GA4 and omit verification tags.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# Server-only Resend configuration. Never expose RESEND_API_KEY to the browser.
RESEND_API_KEY=
RESEND_FROM_EMAIL=TERAS UNIVERSAL <noreply@your-verified-domain.com>

# Server-only Google Apps Script Web App endpoint for the Training Leads sheet.
# The deployed web app must accept JSON POST requests and return {"success":true}.
GOOGLE_SHEETS_WEB_APP_URL=

# Supabase public project credentials. Never use a service role key in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
